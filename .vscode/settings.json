{
    "liveServer.settings.port": 5505,
    "files.associations": {
        "Makefile.*": "makefile",
        "*.txt": "markdown"
    },
    "explorer.compactFolders": false,
    // ✅ Better readability for text files
    "editor.wordWrap": "on",
