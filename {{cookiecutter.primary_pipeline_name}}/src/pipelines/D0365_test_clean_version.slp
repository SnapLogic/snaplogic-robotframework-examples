_mode":{"value":"Validate & Execute"},"preventURLEncoding":{"value":false},"retryInterval":{"value":1,"expression":false},"executeDuringPreview":{"value":true},"advancedProperties":{"value":[]},"enableStaging":{"value":false}},"view_serial":102},"class_build_tag":"main33958"},"0a670f2f-fe02-4157-98da-40fed792dddd":{"class_fqid":"com-snaplogic-snaps-script-script_2-main33142","class_id":"com-snaplogic-snaps-script-script","class_version":2,"instance_fqid":"0a670f2f-fe02-4157-98da-40fed792dddd_1","instance_id":"0a670f2f-fe02-4157-98da-40fed792dddd","instance_version":1,"property_map":{"account":{"account_ref":{"value":{}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}},"input":{"input0":{"label":{"value":"input0"},"view_type":{"value":"document"}}},"info":{"label":{"value":"Script London"},"notes":{"value":""}},"settings":{"language":{"value":"Python"},"editable_content":{"value":"from datetime import datetime\nfrom com.snaplogic.scripting.language import ScriptHook\n\nfrom java.time import ZonedDateTime, ZoneId\nfrom java.time.format import DateTimeFormatter\n\n\nclass TransformScript(ScriptHook):\n    def __init__(self, input, output, error, log):\n        self.input = input\n        self.output = output\n        self.error = error\n        self.log = log\n\n        # Global state - persists across all docs in one execution\n        self.root_key = None\n        _now = ZonedDateTime.now(ZoneId.of(\"Europe/London\"))\n        self.now_str = _now.format(DateTimeFormatter.ofPattern(\"yyyy-MM-dd'T'HH:mm:ss.SSS\"))\n        self.invoice_pos = 0\n        self.cfd_pos = 0\n        self.bp_pos = 0\n        self.di_pos = 0\n        self.ir_pos = 0\n        self.adhoc_pos = 0\n        self.current_invoice = None\n        self.current_cfd = None\n        self.current_bp = None\n        self.current_di = None\n\n        self._KNOWN_TYPES = frozenset([\n            \"ZHV\", \"86I\", \"87I\", \"88I\", \"89I\", \"CME\",\n            \"90I\", \"91I\", \"92I\", \"ZPT\"\n        ])\n\n    def _validate_d365(self, lines):\n        errors = []\n\n        zhv_count = 0\n        ctx_86I = None\n        ctx_87I = None\n        ctx_88I = None\n        ctx_89I = None\n        ctx_90I = None\n        cnt_86I = 0\n\n        cnt_87I_per_86 = {}\n        cnt_88I_per_87 = {}\n        cnt_89I_per_88 = {}\n        cnt_cme_per_89 = {}\n        cnt_90I_per_87 = {}\n        cnt_91I_per_90 = {}\n\n        for line_num, line in enumerate(lines, start=1):\n            rt = line.split(\"|\")[0].strip().upper()\n\n            if rt not in self._KNOWN_TYPES:\n                continue\n\n            if rt == \"ZHV\":\n                zhv_count += 1\n                if zhv_count > 1:\n                    errors.append(\n                        \"Line {}: Duplicate ZHV - only one file header is allowed\".format(line_num)\n                    )\n                ctx_86I = None\n                ctx_87I = None\n                ctx_88I = None\n                ctx_89I = None\n                ctx_90I = None\n                cnt_86I = 0\n\n            elif rt == \"86I\":\n                if zhv_count == 0:\n                    errors.append(\n                        \"Line {}: 86I (Invoice) found before ZHV header\".format(line_num)\n                    )\n                cnt_86I += 1\n                ctx_86I = cnt_86I\n                ctx_87I = None\n                ctx_88I = None\n                ctx_89I = None\n                ctx_90I = None\n                cnt_87I_per_86[ctx_86I] = 0\n\n            elif rt == \"87I\":\n                if ctx_86I is None:\n                    errors.append(\n                        \"Line {}: 87I (CFD) found without a preceding 86I\".format(line_num)\n                    )\n                else:\n                    cnt_87I_per_86[ctx_86I] += 1\n                    if cnt_87I_per_86[ctx_86I] > 1:\n                        errors.append(\n                            \"Line {}: Multiple 87I records under 86I #{} - exactly one CFD allowed per invoice\"\n                            .format(line_num, ctx_86I)\n                        )\n                    ctx_87I = \"{}_{}\".format(ctx_86I, cnt_87I_per_86[ctx_86I])\n                    ctx_88I = None\n                    ctx_89I = None\n                    ctx_90I = None\n                    cnt_88I_per_87[ctx_87I] = 0\n\n            elif rt == \"88I\":\n                if ctx_87I is None:\n                    errors.append(\n                        \"Line {}: 88I (BillingPeriod) found without a preceding 87I\".format(line_num)\n                    )\n                else:\n                    cnt_88I_per_87[ctx_87I] = cnt_88I_per_87.get(ctx_87I, 0) + 1\n                    ctx_88I = \"{}_{}\".format(ctx_87I, cnt_88I_per_87[ctx_87I])\n                    ctx_89I = None\n                    ctx_90I = None\n                    cnt_89I_per_88[ctx_88I] = 0\n\n            elif rt == \"89I\":\n                if ctx_88I is None:\n                    errors.append(\n                        \"Line {}: 89I (SettlementUnit) found without a preceding 88I\".format(line_num)\n                    )\n                else:\n                    cnt_89I_per_88[ctx_88I] = cnt_89I_per_88.get(ctx_88I, 0) + 1\n                    ctx_89I = \"{}_{}\".format(ctx_88I, cnt_89I_per_88[ctx_88I])\n                    ctx_90I = None\n                    cnt_cme_per_89[ctx_89I] = 0\n\n            elif rt == \"CME\":\n                if ctx_89I is None:\n                    errors.append(\n                        \"Line {}: CME (metered entity) found without a preceding 89I\".format(line_num)\n                    )\n                else:\n                    cnt_cme_per_89[ctx_89I] = cnt_cme_per_89.get(ctx_89I, 0) + 1\n\n            elif rt == \"90I\":\n                if ctx_87I is None:\n                    errors.append(\n                        \"Line {}: 90I (DefaultInterest) found without a preceding 87I\".format(line_num)\n                    )\n                else:\n                    cnt_90I_per_87[ctx_87I] = cnt_90I_per_87.get(ctx_87I, 0) + 1\n                    ctx_90I = \"{}_{}\".format(ctx_87I, cnt_90I_per_87[ctx_87I])\n                    cnt_91I_per_90[ctx_90I] = 0\n\n            elif rt == \"91I\":\n                if ctx_90I is None:\n                    errors.append(\n                        \"Line {}: 91I (DefaultInterestRate) found without a preceding 90I\".format(line_num)\n                    )\n                else:\n                    cnt_91I_per_90[ctx_90I] = cnt_91I_per_90.get(ctx_90I, 0) + 1\n\n            elif rt == \"92I\":\n                if ctx_87I is None:\n                    errors.append(\n                        \"Line {}: 92I (AdHocPayment) found without a preceding 87I\".format(line_num)\n                    )\n\n        if zhv_count == 0:\n            errors.append(\"MISSING mandatory ZHV file header - file is empty or malformed\")\n\n        if cnt_86I == 0:\n            errors.append(\"MISSING mandatory 86I (DataFlow/Invoice) - no invoice records found\")\n\n        for k, v in cnt_87I_per_86.items():\n            if v == 0:\n                errors.append(\n                    \"86I #{}: MISSING mandatory 87I (CFD) - each invoice must have exactly one CFD\"\n                    .format(k)\n                )\n\n        for k, v in cnt_88I_per_87.items():\n            if v == 0:\n                errors.append(\n                    \"87I [{}]: MISSING mandatory 88I - each CFD must have at least one BillingPeriod\"\n                    .format(k)\n                )\n\n        for k, v in cnt_89I_per_88.items():\n            if v == 0:\n                errors.append(\n                    \"88I [{}]: MISSING mandatory 89I - each BillingPeriod must have at least one SettlementUnit\"\n                    .format(k)\n                )\n\n        for k, v in cnt_cme_per_89.items():\n            if v == 0:\n                errors.append(\n                    \"89I [{}]: MISSING mandatory CME - each SettlementUnit must have at least one metered entity\"\n                    .format(k)\n                )\n\n        expected_rows = {\n            \"esb.D0365Interchange\": zhv_count,\n            \"esb.EMRInvoiceHeader\": cnt_86I,\n            \"esb.ContractForDifference\": sum(cnt_87I_per_86.values()),\n            \"esb.CFDBillingPeriod\": sum(cnt_88I_per_87.values()),\n            \"esb.CFDSettlementUnit\": sum(cnt_89I_per_88.values()),\n        }\n\n        for table, count in expected_rows.items():\n            if count == 0:\n                errors.append(\n                    \"MANDATORY TABLE {} would receive 0 rows - file rejected\".format(table)\n                )\n\n        return errors, expected_rows\n\n    def f(self, cols, i, optional=False):\n        if i >= len(cols):\n            return None if optional else \"\"\n        v = str(cols[i]).strip() if cols[i] is not None else \"\"\n        if not v:\n            return None if optional else \"\"\n        return v\n\n    def date_val(self, raw):\n        if not raw:\n            return None\n        raw = str(raw).strip()\n        if len(raw) == 8 and raw.isdigit():\n            return \"{}-{}-{}\".format(raw[0:4], raw[4:6], raw[6:8])\n        if len(raw) == 14 and raw.isdigit():\n            return \"{}-{}-{}T{}:{}:{}\".format(\n                raw[0:4], raw[4:6], raw[6:8],\n                raw[8:10], raw[10:12], raw[12:14]\n            )\n        return raw\n\n    def int_val(self, raw):\n        if not raw:\n            return None\n        try:\n            return int(str(raw).strip())\n        except:\n            return raw\n\n    def dec_val(self, raw):\n        if not raw:\n            return None\n        return str(raw).strip()\n\n    def execute(self):\n        while self.input.hasNext():\n            doc = self.input.next()\n            try:\n                content = doc.get(\"content\") or \"\"\n                if not content:\n                    self.log.warn(\"Document has no content field - skipping\")\n                    continue\n\n                raw_lines = []\n                for raw in content.splitlines():\n                    line = raw.strip()\n                    if line.startswith(u'\\ufeff'):\n                        line = line[1:]\n                    if line.endswith(\"|\"):\n                        line = line[:-1]\n                    if line:\n                        raw_lines.append(line)\n\n                self.log.info(\"Processing D0365 file: {} lines\".format(len(raw_lines)))\n\n                validation_errors, expected_rows = self._validate_d365(raw_lines)\n                if validation_errors:\n                    error_detail = \" | \".join(validation_errors)\n                    self.error.write({\n                        \"error\": \"D0365 structural validation failed: \" + error_detail,\n                        \"source\": doc.get(\"x-amz-meta-file_path\") or \"unknown\",\n                        \"errors\": validation_errors\n                    })\n                    self.log.error(\n                        \"D0365 validation FAILED ({} error{}) - file rejected, no rows written\"\n                        .format(len(validation_errors), \"s\" if len(validation_errors) != 1 else \"\")\n                    )\n                    continue\n\n                self.log.info(\"D0365 validation PASSED - expected rows per mandatory table:\")\n                for tbl, cnt in expected_rows.items():\n                    self.log.info(\"  {}: {}\".format(tbl, cnt))\n\n                for line in raw_lines:\n                    cols = line.split(\"|\")\n                    rt = cols[0].strip() if cols else \"\"\n\n                    try:\n                        if rt == \"ZHV\":\n                            fid = self.f(cols, 1)\n                            frd = self.f(cols, 4)\n                            if not fid or not frd:\n                                raise ValueError(\"ZHV missing FileIdentifier or FromId\")\n\n                            self.root_key = fid + \"_\" + frd\n                            self.invoice_pos = 0\n                            self.cfd_pos = 0\n                            self.bp_pos = 0\n                            self.di_pos = 0\n                            self.ir_pos = 0\n                            self.adhoc_pos = 0\n                            self.current_invoice = None\n                            self.current_cfd = None\n                            self.current_bp = None\n                            self.current_di = None\n\n                            self.output.write({\n                                \"_table\": \"esb.D0365Interchange\",\n                                \"D0365InterchangeID\": self.root_key,\n                                \"CreatedDate\": self.now_str,\n                                \"_expected_rows\": expected_rows\n                            })\n\n                        elif rt == \"86I\":\n                            self.invoice_pos += 1\n                            self.cfd_pos = 0\n                            self.di_pos = 0\n                            self.adhoc_pos = 0\n                            self.current_invoice = self.root_key + \"_\" + str(self.invoice_pos)\n\n                            self.output.write({\n                                \"_table\": \"esb.EMRInvoiceHeader\",\n                                \"EMRInvoiceHeaderID\": self.current_invoice,\n                                \"PartyID\": self.f(cols, 1),\n                                \"InvoiceNumber\": self.int_val(self.f(cols, 2)),\n                                \"InvoiceDate\": self.date_val(self.f(cols, 3)),\n                                \"InvoicePaymentDate\": self.date_val(self.f(cols, 4)),\n                                \"InvoiceTotal\": self.dec_val(self.f(cols, 5)),\n                                \"CreatedDate\": self.now_str\n                            })\n\n                        elif rt == \"87I\":\n                            self.cfd_pos += 1\n                            self.bp_pos = 0\n                            self.di_pos = 0\n                            self.ir_pos = 0\n                            self.adhoc_pos = 0\n                            self.current_cfd = self.current_invoice + \"_\" + str(self.cfd_pos)\n\n                            self.output.write({\n                                \"_table\": \"esb.ContractForDifference\",\n                                \"ContractForDifferenceID\": self.current_cfd,\n                                \"EMRInvoiceHeaderID\": self.current_invoice,\n                                \"CFDID\": self.f(cols, 1),\n                                \"ContractType\": self.f(cols, 2),\n                                \"TotalAggregateDifference\": self.dec_val(self.f(cols, 3)),\n                                \"TotalReconciliationAmount\": self.dec_val(self.f(cols, 4)),\n                                \"TotalInterest\": self.dec_val(self.f(cols, 5)),\n                                \"NetPayableAmount\": self.dec_val(self.f(cols, 6)),\n                                \"TotalAdHocPayment\": self.dec_val(self.f(cols, 7))\n                            })\n\n                        elif rt == \"88I\":\n                            self.bp_pos += 1\n                            self.current_bp = self.current_cfd + \"_\" + str(self.bp_pos)\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDBillingPeriod\",\n                                \"CFDBillingPeriodID\": self.current_bp,\n                                \"ContractForDifferenceID\": self.current_cfd,\n                                \"SettlementDate\": self.date_val(self.f(cols, 1)),\n                                \"SettlementCode\": self.f(cols, 2),\n                                \"AggregateDifferenceAmount\": self.dec_val(self.f(cols, 3)),\n                                \"ReconciliationAmount\": self.dec_val(self.f(cols, 4, True)),\n                                \"CompensatoryInterest\": self.dec_val(self.f(cols, 5, True)),\n                                \"Validated\": None\n                            })\n\n                        elif rt == \"89I\":\n                            su_unit = self.f(cols, 1)\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDSettlementUnit\",\n                                \"CFDSettlementUnitID\": self.current_bp + \"_\" + su_unit,\n                                \"CFDBillingPeriodID\": self.current_bp,\n                                \"SettlementUnitID\": self.int_val(su_unit),\n                                \"MeteredVolume\": self.dec_val(self.f(cols, 2)),\n                                \"DSFUnitMeteredVolume\": self.dec_val(self.f(cols, 3, True)),\n                                \"DSFStationLoad\": self.dec_val(self.f(cols, 4, True)),\n                                \"DSFStationLoadProportion\": self.dec_val(self.f(cols, 5, True)),\n                                \"TransmissionLossMultiplier\": self.dec_val(self.f(cols, 6)),\n                                \"ReferencePrice\": self.dec_val(self.f(cols, 7)),\n                                \"StrikePrice\": self.dec_val(self.f(cols, 9)),\n                                \"RenewableQualifyingMultiplier\": self.dec_val(self.f(cols, 11, True)),\n                                \"RenewableQualifyingMultiplierType\": self.f(cols, 12, True),\n                                \"CHPQualifyingMultiplier\": self.dec_val(self.f(cols, 13, True)),\n                                \"Difference\": self.dec_val(self.f(cols, 14)),\n                                \"DifferenceAmount\": self.dec_val(self.f(cols, 15)),\n                                \"Validated\": None\n                            })\n\n                        elif rt in (\"CME\", \"ZPT\"):\n                            pass\n\n                        elif rt == \"90I\":\n                            self.di_pos += 1\n                            self.ir_pos = 0\n                            self.current_di = self.current_cfd + \"_DI\" + str(self.di_pos)\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDDefaultInterest\",\n                                \"CFDDefaultInterestID\": self.current_di,\n                                \"ContractForDifferenceID\": self.current_cfd,\n                                \"EMRInvoiceNumber\": self.int_val(self.f(cols, 1)),\n                                \"EMRInvoiceDate\": self.date_val(self.f(cols, 2)),\n                                \"AmountInDefault\": self.dec_val(self.f(cols, 3)),\n                                \"InterestPaymentFromDate\": self.date_val(self.f(cols, 4)),\n                                \"InterestPaymentToDate\": self.date_val(self.f(cols, 5)),\n                                \"InterestAmount\": self.dec_val(self.f(cols, 6))\n                            })\n\n                        elif rt == \"91I\":\n                            self.ir_pos += 1\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDDefaultInterestRate\",\n                                \"CFDDefaultInterestRateID\": self.current_di + \"_IR\" + str(self.ir_pos),\n                                \"CFDDefaultInterestID\": self.current_di,\n                                \"InterestRateEffectiveDate\": self.date_val(self.f(cols, 1)),\n                                \"InterestRate\": self.dec_val(self.f(cols, 2))\n                            })\n\n                        elif rt == \"92I\":\n                            self.adhoc_pos += 1\n                            fd = self.f(cols, 9, True)\n                            td = self.f(cols, 10, True)\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDAdHocPayment\",\n                                \"CFDAdHocPaymentID\": self.current_cfd + \"_AH\" + str(self.adhoc_pos),\n                                \"ContractForDifferenceID\": self.current_cfd,\n                                \"Description\": self.f(cols, 1),\n                                \"CurtailmentCompAmount\": self.dec_val(self.f(cols, 2, True)),\n                                \"TerminationAmount\": self.dec_val(self.f(cols, 3, True)),\n                                \"QualChangeInLawAmount\": self.dec_val(self.f(cols, 4, True)),\n                                \"GenerationTaxAmount\": self.dec_val(self.f(cols, 5, True)),\n                                \"SustainabilityChangeInLawAmount\": self.dec_val(self.f(cols, 6, True)),\n                                \"OtherCFDAdHocPayment\": self.dec_val(self.f(cols, 7, True)),\n                                \"CompensatoryInterest\": self.dec_val(self.f(cols, 8, True)),\n                                \"CompensatoryInterestFromDate\": self.date_val(fd) if fd else None,\n                                \"CompensatoryInterestToDate\": self.date_val(td) if td else None\n                            })\n\n                        else:\n                            self.log.warn(\"Unknown record type '{}' - skipping\".format(rt))\n\n                    except Exception as line_err:\n                        self.error.write({\n                            \"error\": str(line_err),\n                            \"recordType\": rt,\n                            \"line\": line\n                        })\n\n            except Exception as e:\n                self.error.write({\n                    \"error\": str(e),\n                    \"source\": doc.get(\"x-amz-meta-file_path\") or \"unknown\"\n                })\n\n    def cleanup(self):\n        pass\n\nhook = TransformScript(input, output, error, log)"},"executable_during_suggest":{"value":false},"execution_mode":{"value":"Validate & Execute"},"script":{"value":null,"expression":false}},"view_serial":100},"class_build_tag":"main33142"},"881f3da1-ff3e-40ec-9b14-dcfa0e683bbb":{"class_fqid":"com-snaplogic-snaps-flow-copy_1-main33142","class_id":"com-snaplogic-snaps-flow-copy","class_version":1,"instance_fqid":"881f3da1-ff3e-40ec-9b14-dcfa0e683bbb_1","instance_id":"881f3da1-ff3e-40ec-9b14-dcfa0e683bbb","instance_version":1,"property_map":{"info":{"label":{"value":"Copy1"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"output0"}},"output1":{"view_type":{"value":"document"},"label":{"value":"output1"}},"output101":{"label":{"value":"output2"},"view_type":{"value":"document"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"}},"view_serial":101},"class_build_tag":"main33142"},"067f3b44-03b0-4ff9-94fb-62ea0e2209b2":{"class_fqid":"com-snaplogic-snaps-flow-router_2-main33142","class_id":"com-snaplogic-snaps-flow-router","class_version":2,"instance_fqid":"067f3b44-03b0-4ff9-94fb-62ea0e2209b2_1","instance_id":"067f3b44-03b0-4ff9-94fb-62ea0e2209b2","instance_version":1,"property_map":{"info":{"label":{"value":"Router"},"notes":{}},"input":{"input0":{"view_type":{"value":"document"},"label":{"value":"input0"}}},"output":{"output0":{"view_type":{"value":"document"},"label":{"value":"D0365Interchange"}},"output1":{"view_type":{"value":"document"},"label":{"value":"EMRInvoiceHeader"}},"output101":{"label":{"value":"ContractForDifferenc"},"view_type":{"value":"document"}},"output102":{"label":{"value":"CFDBillingPeriod"},"view_type":{"value":"document"}},"output103":{"label":{"value":"CFDSettlementUnit"},"view_type":{"value":"document"}},"output104":{"label":{"value":"CFDDefaultInterest"},"view_type":{"value":"document"}},"output105":{"label":{"value":"CFDDefaultInterestRate"},"view_type":{"value":"document"}},"output106":{"label":{"value":"CFDAdHocPayment"},"view_type":{"value":"document"}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"settings":{"execution_mode":{"value":"Validate & Execute"},"routes":{"value":[{"expression":{"expression":true,"value":"$_table == \"esb.D0365Interchange\""},"outputViewName":{"value":"D0365Interchange"}},{"expression":{"expression":true,"value":"$_table == \"esb.EMRInvoiceHeader\""},"outputViewName":{"value":"EMRInvoiceHeader"}},{"expression":{"value":"$_table == \"esb.ContractForDifference\"","expression":true},"outputViewName":{"value":"ContractForDifferenc"}},{"expression":{"value":"$_table == \"esb.CFDBillingPeriod\"","expression":true},"outputViewName":{"value":"CFDBillingPeriod"}},{"expression":{"value":"$_table == \"esb.CFDSettlementUnit\"","expression":true},"outputViewName":{"value":"CFDSettlementUnit"}},{"expression":{"value":"$_table == \"esb.CFDDefaultInterest\" ","expression":true},"outputViewName":{"value":"CFDDefaultInterest"}},{"expression":{"value":"$_table == \"esb.CFDDefaultInterestRate\"","expression":true},"outputViewName":{"value":"CFDDefaultInterestRate"}},{"expression":{"value":"$_table == \"esb.CFDAdHocPayment\"","expression":true},"outputViewName":{"value":"CFDAdHocPayment"}}]},"firstMatch":{"value":false}},"view_serial":106},"class_build_tag":"main33142"},"fefe9d91-bfad-4981-bb5b-2dd708b39859":{"class_fqid":"com-snaplogic-snaps-script-script_2-main33142","class_id":"com-snaplogic-snaps-script-script","class_version":2,"instance_fqid":"fefe9d91-bfad-4981-bb5b-2dd708b39859_1","instance_id":"fefe9d91-bfad-4981-bb5b-2dd708b39859","instance_version":1,"property_map":{"account":{"account_ref":{"value":{}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}},"input":{"input0":{"label":{"value":"input0"},"view_type":{"value":"document"}}},"info":{"label":{"value":"Script UTC"},"notes":{"value":""}},"settings":{"language":{"value":"Python"},"editable_content":{"value":"from datetime import datetime\nfrom com.snaplogic.scripting.language import ScriptHook\n\nfrom java.time import ZonedDateTime, ZoneId\nfrom java.time.format import DateTimeFormatter\n\n\nclass TransformScript(ScriptHook):\n    def __init__(self, input, output, error, log):\n        self.input = input\n        self.output = output\n        self.error = error\n        self.log = log\n\n        # Global state - persists across all docs in one execution\n        self.root_key = None\n        self.now_str = datetime.utcnow().strftime(\"%Y-%m-%dT%H:%M:%S.%f\")[:-3]\n        self.invoice_pos = 0\n        self.cfd_pos = 0\n        self.bp_pos = 0\n        self.di_pos = 0\n        self.ir_pos = 0\n        self.adhoc_pos = 0\n        self.current_invoice = None\n        self.current_cfd = None\n        self.current_bp = None\n        self.current_di = None\n\n        self._KNOWN_TYPES = frozenset([\n            \"ZHV\", \"86I\", \"87I\", \"88I\", \"89I\", \"CME\",\n            \"90I\", \"91I\", \"92I\", \"ZPT\"\n        ])\n\n    def _validate_d365(self, lines):\n        errors = []\n\n        zhv_count = 0\n        ctx_86I = None\n        ctx_87I = None\n        ctx_88I = None\n        ctx_89I = None\n        ctx_90I = None\n        cnt_86I = 0\n\n        cnt_87I_per_86 = {}\n        cnt_88I_per_87 = {}\n        cnt_89I_per_88 = {}\n        cnt_cme_per_89 = {}\n        cnt_90I_per_87 = {}\n        cnt_91I_per_90 = {}\n\n        for line_num, line in enumerate(lines, start=1):\n            rt = line.split(\"|\")[0].strip().upper()\n\n            if rt not in self._KNOWN_TYPES:\n                continue\n\n            if rt == \"ZHV\":\n                zhv_count += 1\n                if zhv_count > 1:\n                    errors.append(\n                        \"Line {}: Duplicate ZHV - only one file header is allowed\".format(line_num)\n                    )\n                ctx_86I = None\n                ctx_87I = None\n                ctx_88I = None\n                ctx_89I = None\n                ctx_90I = None\n                cnt_86I = 0\n\n            elif rt == \"86I\":\n                if zhv_count == 0:\n                    errors.append(\n                        \"Line {}: 86I (Invoice) found before ZHV header\".format(line_num)\n                    )\n                cnt_86I += 1\n                ctx_86I = cnt_86I\n                ctx_87I = None\n                ctx_88I = None\n                ctx_89I = None\n                ctx_90I = None\n                cnt_87I_per_86[ctx_86I] = 0\n\n            elif rt == \"87I\":\n                if ctx_86I is None:\n                    errors.append(\n                        \"Line {}: 87I (CFD) found without a preceding 86I\".format(line_num)\n                    )\n                else:\n                    cnt_87I_per_86[ctx_86I] += 1\n                    if cnt_87I_per_86[ctx_86I] > 1:\n                        errors.append(\n                            \"Line {}: Multiple 87I records under 86I #{} - exactly one CFD allowed per invoice\"\n                            .format(line_num, ctx_86I)\n                        )\n                    ctx_87I = \"{}_{}\".format(ctx_86I, cnt_87I_per_86[ctx_86I])\n                    ctx_88I = None\n                    ctx_89I = None\n                    ctx_90I = None\n                    cnt_88I_per_87[ctx_87I] = 0\n\n            elif rt == \"88I\":\n                if ctx_87I is None:\n                    errors.append(\n                        \"Line {}: 88I (BillingPeriod) found without a preceding 87I\".format(line_num)\n                    )\n                else:\n                    cnt_88I_per_87[ctx_87I] = cnt_88I_per_87.get(ctx_87I, 0) + 1\n                    ctx_88I = \"{}_{}\".format(ctx_87I, cnt_88I_per_87[ctx_87I])\n                    ctx_89I = None\n                    ctx_90I = None\n                    cnt_89I_per_88[ctx_88I] = 0\n\n            elif rt == \"89I\":\n                if ctx_88I is None:\n                    errors.append(\n                        \"Line {}: 89I (SettlementUnit) found without a preceding 88I\".format(line_num)\n                    )\n                else:\n                    cnt_89I_per_88[ctx_88I] = cnt_89I_per_88.get(ctx_88I, 0) + 1\n                    ctx_89I = \"{}_{}\".format(ctx_88I, cnt_89I_per_88[ctx_88I])\n                    ctx_90I = None\n                    cnt_cme_per_89[ctx_89I] = 0\n\n            elif rt == \"CME\":\n                if ctx_89I is None:\n                    errors.append(\n                        \"Line {}: CME (metered entity) found without a preceding 89I\".format(line_num)\n                    )\n                else:\n                    cnt_cme_per_89[ctx_89I] = cnt_cme_per_89.get(ctx_89I, 0) + 1\n\n            elif rt == \"90I\":\n                if ctx_87I is None:\n                    errors.append(\n                        \"Line {}: 90I (DefaultInterest) found without a preceding 87I\".format(line_num)\n                    )\n                else:\n                    cnt_90I_per_87[ctx_87I] = cnt_90I_per_87.get(ctx_87I, 0) + 1\n                    ctx_90I = \"{}_{}\".format(ctx_87I, cnt_90I_per_87[ctx_87I])\n                    cnt_91I_per_90[ctx_90I] = 0\n\n            elif rt == \"91I\":\n                if ctx_90I is None:\n                    errors.append(\n                        \"Line {}: 91I (DefaultInterestRate) found without a preceding 90I\".format(line_num)\n                    )\n                else:\n                    cnt_91I_per_90[ctx_90I] = cnt_91I_per_90.get(ctx_90I, 0) + 1\n\n            elif rt == \"92I\":\n                if ctx_87I is None:\n                    errors.append(\n                        \"Line {}: 92I (AdHocPayment) found without a preceding 87I\".format(line_num)\n                    )\n\n        if zhv_count == 0:\n            errors.append(\"MISSING mandatory ZHV file header - file is empty or malformed\")\n\n        if cnt_86I == 0:\n            errors.append(\"MISSING mandatory 86I (DataFlow/Invoice) - no invoice records found\")\n\n        for k, v in cnt_87I_per_86.items():\n            if v == 0:\n                errors.append(\n                    \"86I #{}: MISSING mandatory 87I (CFD) - each invoice must have exactly one CFD\"\n                    .format(k)\n                )\n\n        for k, v in cnt_88I_per_87.items():\n            if v == 0:\n                errors.append(\n                    \"87I [{}]: MISSING mandatory 88I - each CFD must have at least one BillingPeriod\"\n                    .format(k)\n                )\n\n        for k, v in cnt_89I_per_88.items():\n            if v == 0:\n                errors.append(\n                    \"88I [{}]: MISSING mandatory 89I - each BillingPeriod must have at least one SettlementUnit\"\n                    .format(k)\n                )\n\n        for k, v in cnt_cme_per_89.items():\n            if v == 0:\n                errors.append(\n                    \"89I [{}]: MISSING mandatory CME - each SettlementUnit must have at least one metered entity\"\n                    .format(k)\n                )\n\n        expected_rows = {\n            \"esb.D0365Interchange\": zhv_count,\n            \"esb.EMRInvoiceHeader\": cnt_86I,\n            \"esb.ContractForDifference\": sum(cnt_87I_per_86.values()),\n            \"esb.CFDBillingPeriod\": sum(cnt_88I_per_87.values()),\n            \"esb.CFDSettlementUnit\": sum(cnt_89I_per_88.values()),\n        }\n\n        for table, count in expected_rows.items():\n            if count == 0:\n                errors.append(\n                    \"MANDATORY TABLE {} would receive 0 rows - file rejected\".format(table)\n                )\n\n        return errors, expected_rows\n\n    def f(self, cols, i, optional=False):\n        if i >= len(cols):\n            return None if optional else \"\"\n        v = str(cols[i]).strip() if cols[i] is not None else \"\"\n        if not v:\n            return None if optional else \"\"\n        return v\n\n    def date_val(self, raw):\n        if not raw:\n            return None\n        raw = str(raw).strip()\n        if len(raw) == 8 and raw.isdigit():\n            return \"{}-{}-{}\".format(raw[0:4], raw[4:6], raw[6:8])\n        if len(raw) == 14 and raw.isdigit():\n            return \"{}-{}-{}T{}:{}:{}\".format(\n                raw[0:4], raw[4:6], raw[6:8],\n                raw[8:10], raw[10:12], raw[12:14]\n            )\n        return raw\n\n    def int_val(self, raw):\n        if not raw:\n            return None\n        try:\n            return int(str(raw).strip())\n        except:\n            return raw\n\n    def dec_val(self, raw):\n        if not raw:\n            return None\n        return str(raw).strip()\n\n    def execute(self):\n        while self.input.hasNext():\n            doc = self.input.next()\n            try:\n                content = doc.get(\"content\") or \"\"\n                if not content:\n                    self.log.warn(\"Document has no content field - skipping\")\n                    continue\n\n                raw_lines = []\n                for raw in content.splitlines():\n                    line = raw.strip()\n                    if line.startswith(u'\\ufeff'):\n                        line = line[1:]\n                    if line.endswith(\"|\"):\n                        line = line[:-1]\n                    if line:\n                        raw_lines.append(line)\n\n                self.log.info(\"Processing D0365 file: {} lines\".format(len(raw_lines)))\n\n                validation_errors, expected_rows = self._validate_d365(raw_lines)\n                if validation_errors:\n                    error_detail = \" | \".join(validation_errors)\n                    self.error.write({\n                        \"error\": \"D0365 structural validation failed: \" + error_detail,\n                        \"source\": doc.get(\"x-amz-meta-file_path\") or \"unknown\",\n                        \"errors\": validation_errors\n                    })\n                    self.log.error(\n                        \"D0365 validation FAILED ({} error{}) - file rejected, no rows written\"\n                        .format(len(validation_errors), \"s\" if len(validation_errors) != 1 else \"\")\n                    )\n                    continue\n\n                self.log.info(\"D0365 validation PASSED - expected rows per mandatory table:\")\n                for tbl, cnt in expected_rows.items():\n                    self.log.info(\"  {}: {}\".format(tbl, cnt))\n\n                for line in raw_lines:\n                    cols = line.split(\"|\")\n                    rt = cols[0].strip() if cols else \"\"\n\n                    try:\n                        if rt == \"ZHV\":\n                            fid = self.f(cols, 1)\n                            frd = self.f(cols, 4)\n                            if not fid or not frd:\n                                raise ValueError(\"ZHV missing FileIdentifier or FromId\")\n\n                            self.root_key = fid + \"_\" + frd\n                            self.invoice_pos = 0\n                            self.cfd_pos = 0\n                            self.bp_pos = 0\n                            self.di_pos = 0\n                            self.ir_pos = 0\n                            self.adhoc_pos = 0\n                            self.current_invoice = None\n                            self.current_cfd = None\n                            self.current_bp = None\n                            self.current_di = None\n\n                            self.output.write({\n                                \"_table\": \"esb.D0365Interchange\",\n                                \"D0365InterchangeID\": self.root_key,\n                                \"CreatedDate\": self.now_str,\n                                \"_expected_rows\": expected_rows\n                            })\n\n                        elif rt == \"86I\":\n                            self.invoice_pos += 1\n                            self.cfd_pos = 0\n                            self.di_pos = 0\n                            self.adhoc_pos = 0\n                            self.current_invoice = self.root_key + \"_\" + str(self.invoice_pos)\n\n                            self.output.write({\n                                \"_table\": \"esb.EMRInvoiceHeader\",\n                                \"EMRInvoiceHeaderID\": self.current_invoice,\n                                \"PartyID\": self.f(cols, 1),\n                                \"InvoiceNumber\": self.int_val(self.f(cols, 2)),\n                                \"InvoiceDate\": self.date_val(self.f(cols, 3)),\n                                \"InvoicePaymentDate\": self.date_val(self.f(cols, 4)),\n                                \"InvoiceTotal\": self.dec_val(self.f(cols, 5)),\n                                \"CreatedDate\": self.now_str\n                            })\n\n                        elif rt == \"87I\":\n                            self.cfd_pos += 1\n                            self.bp_pos = 0\n                            self.di_pos = 0\n                            self.ir_pos = 0\n                            self.adhoc_pos = 0\n                            self.current_cfd = self.current_invoice + \"_\" + str(self.cfd_pos)\n\n                            self.output.write({\n                                \"_table\": \"esb.ContractForDifference\",\n                                \"ContractForDifferenceID\": self.current_cfd,\n                                \"EMRInvoiceHeaderID\": self.current_invoice,\n                                \"CFDID\": self.f(cols, 1),\n                                \"ContractType\": self.f(cols, 2),\n                                \"TotalAggregateDifference\": self.dec_val(self.f(cols, 3)),\n                                \"TotalReconciliationAmount\": self.dec_val(self.f(cols, 4)),\n                                \"TotalInterest\": self.dec_val(self.f(cols, 5)),\n                                \"NetPayableAmount\": self.dec_val(self.f(cols, 6)),\n                                \"TotalAdHocPayment\": self.dec_val(self.f(cols, 7))\n                            })\n\n                        elif rt == \"88I\":\n                            self.bp_pos += 1\n                            self.current_bp = self.current_cfd + \"_\" + str(self.bp_pos)\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDBillingPeriod\",\n                                \"CFDBillingPeriodID\": self.current_bp,\n                                \"ContractForDifferenceID\": self.current_cfd,\n                                \"SettlementDate\": self.date_val(self.f(cols, 1)),\n                                \"SettlementCode\": self.f(cols, 2),\n                                \"AggregateDifferenceAmount\": self.dec_val(self.f(cols, 3)),\n                                \"ReconciliationAmount\": self.dec_val(self.f(cols, 4, True)),\n                                \"CompensatoryInterest\": self.dec_val(self.f(cols, 5, True)),\n                                \"Validated\": None\n                            })\n\n                        elif rt == \"89I\":\n                            su_unit = self.f(cols, 1)\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDSettlementUnit\",\n                                \"CFDSettlementUnitID\": self.current_bp + \"_\" + su_unit,\n                                \"CFDBillingPeriodID\": self.current_bp,\n                                \"SettlementUnitID\": self.int_val(su_unit),\n                                \"MeteredVolume\": self.dec_val(self.f(cols, 2)),\n                                \"DSFUnitMeteredVolume\": self.dec_val(self.f(cols, 3, True)),\n                                \"DSFStationLoad\": self.dec_val(self.f(cols, 4, True)),\n                                \"DSFStationLoadProportion\": self.dec_val(self.f(cols, 5, True)),\n                                \"TransmissionLossMultiplier\": self.dec_val(self.f(cols, 6)),\n                                \"ReferencePrice\": self.dec_val(self.f(cols, 7)),\n                                \"StrikePrice\": self.dec_val(self.f(cols, 9)),\n                                \"RenewableQualifyingMultiplier\": self.dec_val(self.f(cols, 11, True)),\n                                \"RenewableQualifyingMultiplierType\": self.f(cols, 12, True),\n                                \"CHPQualifyingMultiplier\": self.dec_val(self.f(cols, 13, True)),\n                                \"Difference\": self.dec_val(self.f(cols, 14)),\n                                \"DifferenceAmount\": self.dec_val(self.f(cols, 15)),\n                                \"Validated\": None\n                            })\n\n                        elif rt in (\"CME\", \"ZPT\"):\n                            pass\n\n                        elif rt == \"90I\":\n                            self.di_pos += 1\n                            self.ir_pos = 0\n                            self.current_di = self.current_cfd + \"_DI\" + str(self.di_pos)\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDDefaultInterest\",\n                                \"CFDDefaultInterestID\": self.current_di,\n                                \"ContractForDifferenceID\": self.current_cfd,\n                                \"EMRInvoiceNumber\": self.int_val(self.f(cols, 1)),\n                                \"EMRInvoiceDate\": self.date_val(self.f(cols, 2)),\n                                \"AmountInDefault\": self.dec_val(self.f(cols, 3)),\n                                \"InterestPaymentFromDate\": self.date_val(self.f(cols, 4)),\n                                \"InterestPaymentToDate\": self.date_val(self.f(cols, 5)),\n                                \"InterestAmount\": self.dec_val(self.f(cols, 6))\n                            })\n\n                        elif rt == \"91I\":\n                            self.ir_pos += 1\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDDefaultInterestRate\",\n                                \"CFDDefaultInterestRateID\": self.current_di + \"_IR\" + str(self.ir_pos),\n                                \"CFDDefaultInterestID\": self.current_di,\n                                \"InterestRateEffectiveDate\": self.date_val(self.f(cols, 1)),\n                                \"InterestRate\": self.dec_val(self.f(cols, 2))\n                            })\n\n                        elif rt == \"92I\":\n                            self.adhoc_pos += 1\n                            fd = self.f(cols, 9, True)\n                            td = self.f(cols, 10, True)\n\n                            self.output.write({\n                                \"_table\": \"esb.CFDAdHocPayment\",\n                                \"CFDAdHocPaymentID\": self.current_cfd + \"_AH\" + str(self.adhoc_pos),\n                                \"ContractForDifferenceID\": self.current_cfd,\n                                \"Description\": self.f(cols, 1),\n                                \"CurtailmentCompAmount\": self.dec_val(self.f(cols, 2, True)),\n                                \"TerminationAmount\": self.dec_val(self.f(cols, 3, True)),\n                                \"QualChangeInLawAmount\": self.dec_val(self.f(cols, 4, True)),\n                                \"GenerationTaxAmount\": self.dec_val(self.f(cols, 5, True)),\n                                \"SustainabilityChangeInLawAmount\": self.dec_val(self.f(cols, 6, True)),\n                                \"OtherCFDAdHocPayment\": self.dec_val(self.f(cols, 7, True)),\n                                \"CompensatoryInterest\": self.dec_val(self.f(cols, 8, True)),\n                                \"CompensatoryInterestFromDate\": self.date_val(fd) if fd else None,\n                                \"CompensatoryInterestToDate\": self.date_val(td) if td else None\n                            })\n\n                        else:\n                            self.log.warn(\"Unknown record type '{}' - skipping\".format(rt))\n\n                    except Exception as line_err:\n                        self.error.write({\n                            \"error\": str(line_err),\n                            \"recordType\": rt,\n                            \"line\": line\n                        })\n\n            except Exception as e:\n                self.error.write({\n                    \"error\": str(e),\n                    \"source\": doc.get(\"x-amz-meta-file_path\") or \"unknown\"\n                })\n\n    def cleanup(self):\n        pass\n\nhook = TransformScript(input, output, error, log)"},"executable_during_suggest":{"value":false},"execution_mode":{"value":"Disabled"},"script":{"value":null,"expression":false}},"view_serial":100},"class_build_tag":"main33142"}},"path_id":"/ml-legacy-migration/test9_project_space/sl_project","path_snode":"69f8ee9a0808ef16eaea75f1"}