 for when any field is empty in tables","created":"2026-03-27T10:58:26.097Z","width":"200px","height":"145px","x":67.02104276914598,"y":586.4531137032524},"6f5f13ca-0fc6-4caf-9a09-bd2828cc1c4e":{"creator":"Angelica Tacca Dughetti","content":"the OPTIONAL ONES","created":"2026-04-08T14:00:43.829Z","width":"215px","height":"80px","x":700.553421128513,"y":306.57903791955334}},"snapgpt_extra":{"no_wizard":{"value":true}}},"snap_map":{"2737ca60-8112-44a0-9eb6-930805525b75":{"class_fqid":"com-snaplogic-snaps-transform-binarytodocument_1-main33958","class_id":"com-snaplogic-snaps-transform-binarytodocument","class_version":1,"instance_fqid":"2737ca60-8112-44a0-9eb6-930805525b75_1","instance_id":"2737ca60-8112-44a0-9eb6-930805525b75","instance_version":1,"property_map":{"account":{"account_ref":{"value":{}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}},"input":{"input0":{"label":{"value":"input0"},"view_type":{"value":"binary"}}},"info":{"label":{"value":"Binary to Document"},"notes":{"value":""}},"settings":{"codec":{"value":"NONE"},"ignoreEmptyStream":{"value":false},"execution_mode":{"value":"Validate & Execute"}},"view_serial":100},"class_build_tag":"main33958"},"76aa0b94-14fd-48a1-8539-75034286c03f":{"class_fqid":"com-snaplogic-snaps-transform-datatransform_4-main33142","class_id":"com-snaplogic-snaps-transform-datatransform","class_version":4,"instance_fqid":"76aa0b94-14fd-48a1-8539-75034286c03f_1","instance_id":"76aa0b94-14fd-48a1-8539-75034286c03f","instance_version":1,"property_map":{"account":{"account_ref":{"value":{}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}},"input":{"input0":{"label":{"value":"input0"},"view_type":{"value":"document"}}},"info":{"label":{