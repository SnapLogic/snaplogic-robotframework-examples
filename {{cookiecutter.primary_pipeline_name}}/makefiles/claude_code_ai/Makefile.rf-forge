# =============================================================================
# 🔧 End-to-End
# =============================================================================

## Generate complete E2E test suite (accounts + uploads + pipeline + tasks + verify)
rf-e2e:
ifndef INSTRUCTION
ifndef FILE
	$(error ❌ INSTRUCTION is required. Usage: make rf-e2e INSTRUCTION="MySQL E2E tests")
endif
endif
	@$(RF_FORGE) end-to-end-pipeline-verification $(if $(INSTRUCTION),"$(INSTRUCTION)",) \
		--codebase-path $(CODEBASE) \
		--model $(MODEL) \
		$(_RF_OPTS)


# =============================================================================
# 🔍 Pipeline Analysis
# =============================================================================

## Analyze .slp pipeline file — extract accounts, parameters, snaps, data flow
rf-analyze-pipeline:
ifndef INSTRUCTION
ifndef FILE
	$(error ❌ INSTRUCTION is required. Usage: make rf-analyze-pipeline INSTRUCTION="Analyze oracle.slp")
endif
endif
	@$(RF_FORGE) analyze-pipeline $(if $(INSTRUCTION),"$(INSTRUCTION)",) \
		--codebase-path $(CODEBASE) \
		--model $(MODEL) \
		$(_RF_OPTS)
