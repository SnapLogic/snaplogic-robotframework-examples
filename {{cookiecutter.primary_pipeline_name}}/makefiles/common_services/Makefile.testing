# =============================================================================
# Testing & Test Execution Targets
# =============================================================================
# This file contains all Robot Framework test execution related targets
# including single tests, parallel execution, and test reporting
# =============================================================================

.PHONY: robot-run-tests robot-run-all-tests robot-run-tests-no-gp cleanup-stale-projects slack-notify upload-test-results upload-test-results-cli sl-export-assets sl-import-assets sl-export-assets-full sl-import-assets-full

# Include common configuration
include makefiles/common_services/Makefile.common

# =============================================================================
# 🧪 Run Robot Framework tests with optional tags
#   → usage: make robot-run-tests TAGS="oracle,minio" PROJECT_SPACE_SETUP=True
#   → usage with ENV override: make robot-run-tests TAGS="oracle" ENV=.env.stage
# =============================================================================
robot-run-tests: check-env
	@echo "🧪 Starting Robot Framework tests..."
	@$(MAKE) sync-env
	@echo "ℹ️ Tags: $(TAGS)"
	$(eval INCLUDES=$(foreach arg,$(TAGS),--include $(arg)))
	$(eval PROJECT_SPACE_SETUP_VAL=$(if $(PROJECT_SPACE_SETUP),$(PROJECT_SPACE_SETUP),True))
	$(eval FORCE_RECREATE_VAL=$(if $(FORCE_RECREATE_PROJECT_SPACE),$(FORCE_RECREATE_PROJECT_SPACE),False))
	$(eval ENV_OVERRIDE_VAR=$(if $(ENV),--variable ENV_OVERRIDE_FILE:/app/$(notdir $(ENV)),))
	@if [ -n "$(ENV)" ]; then \
		echo "ℹ️ ENV override: $(ENV) -> copying to container..."; \
		docker cp "$(ENV)" snaplogic-test-example-tools-container:/app/$(notdir $(ENV)); \
	fi
	@if [ "$(FORCE_RECREATE_VAL)" = "True" ] && [ "$(FORCE_CONFIRM)" != "yes" ]; then \
		PROJECT_SPACE_VAL=$$(grep -E '^PROJECT_SPACE=' .env | cut -d '=' -f 2); \
		echo ""; \
		echo "⚠️  ============================================================"; \
		echo "⚠️  DESTRUCTIVE: FORCE_RECREATE_PROJECT_SPACE=True"; \
		echo "⚠️  This will DELETE project space '$$PROJECT_SPACE_VAL' and"; \
		echo "⚠️  ALL projects/pipelines/accounts/tasks inside it."; \
		echo "⚠️  ============================================================"; \
		printf "Type the project space name to confirm (or Ctrl+C to abort): "; \
		read confirm; \
		if [ "$$confirm" != "$$PROJECT_SPACE_VAL" ]; then \
			echo "❌ Confirmation failed. Aborting."; \
			exit 1; \
		fi; \
		echo "✅ Confirmed. Proceeding with destructive recreate..."; \
	fi
	@set -e; \
	if $(DOCKER_COMPOSE) exec -w /app/test tools robot \
		-G $(DATE) \
		--timestampoutputs \
		--variable PROJECT_SPACE_SETUP:$(PROJECT_SPACE_SETUP_VAL) \
		--variable FORCE_RECREATE_PROJECT_SPACE:$(FORCE_RECREATE_VAL) \
		--variable TAGS:"$(TAGS)" \
		$(ENV_OVERRIDE_VAR) \
		$(INCLUDES) \
		--outputdir robot_output suite/; then \
		echo "✅ Tests completed successfully!"; \
	else \
		rc=$$?; \
		echo "❌ Robot exited with code $$rc. See test/robot_output/log-*.html for details."; \
		exit $$rc; \
	fi

# =============================================================================
# 🧪 End-to-End Robot Test Workflow (including environment setup)
#
#  PROJECT_SPACE_SETUP=True is now the DEFAULT (idempotent, non-destructive):
#    - Project space missing → created with ${PROJECT_NAME}.
#    - Project space exists but ${PROJECT_NAME} missing → only project created.
#    - Both already exist → no-op; the run reuses the existing project.
#    - Other projects in the same space are NEVER touched.
#    - Snaplex definition is registered (idempotent) and .slpropz downloaded.
#    Example: make robot-run-all-tests TAGS="oracle,minio"
#
#  PROJECT_SPACE_SETUP=False (verify-only / fast-fail):
#    - Skips Snaplex registration + .slpropz download.
#    - Runs ONLY the verify_project_space_exists test — fails fast if the
#      project space is missing.
#    - Useful for shared orgs where you don't have create permissions, or
#      for CI sanity checks that just want to confirm setup is already in place.
#    Example: make robot-run-all-tests TAGS="oracle" PROJECT_SPACE_SETUP=False
#
#  FORCE_RECREATE_PROJECT_SPACE=True (DESTRUCTIVE — opt-in):
#    - Deletes the ENTIRE project space and every project/pipeline/account inside.
#    - Requires interactive confirmation (type the project space name).
#    - For CI, bypass the prompt with FORCE_CONFIRM=yes.
#    - Use ONLY on dedicated CI/regression project spaces.
#    Example: make robot-run-all-tests TAGS="oracle" FORCE_RECREATE_PROJECT_SPACE=True
# =============================================================================
robot-run-all-tests: check-env
	@# ── Phase 0a: External-plex guard ──────────────────────────────────────────
	@# robot-run-all-tests manages a local Docker Groundplex (Phase 2). If the
	@# user declared EXTERNAL_GROUNDPLEX=yes in .env, they're running against an
	@# externally-managed plex — this target is the wrong tool. Fail fast and
	@# steer them to robot-run-tests-no-gp.
	@#
	@# If the flag is NOT set, a soft heuristic checks whether a local container
	@# or .slpropz already exists. If neither does, the user gets a warning (not
	@# a block) because this could also be a legitimate first run.
	@EXTERNAL_GP=$$(grep -E '^EXTERNAL_GROUNDPLEX=' .env 2>/dev/null | cut -d '=' -f 2 | tr '[:upper:]' '[:lower:]'); \
	GROUNDPLEX_NAME_VAL=$$(grep -E '^GROUNDPLEX_NAME=' .env | cut -d '=' -f 2); \
	if [ "$$EXTERNAL_GP" = "yes" ] || [ "$$EXTERNAL_GP" = "true" ]; then \
		echo ""; \
		echo "❌ ============================================================"; \
		echo "❌  robot-run-all-tests CANNOT BE USED with EXTERNAL_GROUNDPLEX=yes"; \
		echo "❌ ============================================================"; \
		echo ""; \
		echo "   robot-run-all-tests manages a local Docker Groundplex (Phase 2)."; \
		echo "   Your .env declares EXTERNAL_GROUNDPLEX=yes, meaning your"; \
		echo "   Groundplex '$$GROUNDPLEX_NAME_VAL' is externally managed — the"; \
		echo "   framework should not create, start, or stop it."; \
		echo ""; \
		echo "   💡 What you probably want:"; \
		echo "     make robot-run-tests-no-gp TAGS=\"$(TAGS)\""; \
		echo "       → runs tests against your external plex (framework never"; \
		echo "         touches the Groundplex — you manage it)."; \
		echo ""; \
		echo "   If this is wrong, remove EXTERNAL_GROUNDPLEX from .env and re-run."; \
		echo "❌ ============================================================"; \
		echo ""; \
		exit 1; \
	fi; \
	SLPROPZ_PATH="test/.config/$$GROUNDPLEX_NAME_VAL.slpropz"; \
	if ! docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q '^snaplogic-groundplex$$' \
	   && [ ! -f "$$SLPROPZ_PATH" ]; then \
		echo ""; \
		echo "⚠️  ============================================================"; \
		echo "⚠️   NO LOCAL GROUNDPLEX HISTORY FOUND FOR '$$GROUNDPLEX_NAME_VAL'"; \
		echo "⚠️  ============================================================"; \
		echo ""; \
		echo "   No local 'snaplogic-groundplex' container exists and no"; \
		echo "   .slpropz file found at $$SLPROPZ_PATH."; \
		echo ""; \
		echo "   This is EXPECTED if this is your first run — the framework will"; \
		echo "   create the Snaplex and start a local Groundplex for you."; \
		echo ""; \
		echo "   But if '$$GROUNDPLEX_NAME_VAL' is an EXTERNAL Groundplex"; \
		echo "   (Cloud-hosted, shared, or managed outside this framework):"; \
		echo "     → Use: make robot-run-tests-no-gp TAGS=\"$(TAGS)\""; \
		echo "     → Or add EXTERNAL_GROUNDPLEX=yes to .env to always block this target."; \
		echo ""; \
		echo "   Continuing in 5 seconds... (Ctrl+C to abort)"; \
		echo "⚠️  ============================================================"; \
		sleep 5; \
	fi
	@echo ":========== [Phase 0] Pre-swap safety check (before any cloud changes) =========="
	@$(MAKE) check-groundplex-swap || exit $$?
	@PROJECT_SPACE_SETUP_ACTUAL=$${PROJECT_SPACE_SETUP:-True}; \
	FORCE_RECREATE_ACTUAL=$${FORCE_RECREATE_PROJECT_SPACE:-False}; \
	echo ":========== [Phase 1] Create project space and create plex inside project space =========="; \
	if [ "$$PROJECT_SPACE_SETUP_ACTUAL" = "True" ]; then \
		echo ":========= [Phase 1] Running createplex tests ========================================="; \
		echo "ℹ️  FORCE_RECREATE_PROJECT_SPACE=$$FORCE_RECREATE_ACTUAL (safe default=False)"; \
		$(MAKE) robot-run-tests TAGS="createplex" PROJECT_SPACE_SETUP=True FORCE_RECREATE_PROJECT_SPACE=$$FORCE_RECREATE_ACTUAL FORCE_CONFIRM=$${FORCE_CONFIRM:-} || { \
			echo "❌ createplex test failed, checking if error is due to active Snaplex nodes..."; \
			LATEST_LOG=$$(ls -t test/robot_output/log-*.html 2>/dev/null | head -1); \
			if [ -n "$$LATEST_LOG" ] && grep -q "cannot be deleted while it contains active nodes" "$$LATEST_LOG" 2>/dev/null; then \
				echo "🛑 Active Groundplex nodes detected (in $$LATEST_LOG) — killing Groundplex and retrying to create project space and plex..."; \
				$(MAKE) stop-groundplex; \
				echo "⏳ Waiting 60 seconds for nodes to deregister from SnapLogic Cloud..."; \
				sleep 60; \
				$(MAKE) robot-run-tests TAGS="createplex" PROJECT_SPACE_SETUP=True FORCE_RECREATE_PROJECT_SPACE=$$FORCE_RECREATE_ACTUAL FORCE_CONFIRM=$${FORCE_CONFIRM:-} || exit 1; \
			else \
				echo "❌ createplex test failed for a different reason."; \
				exit 1; \
			fi; \
		}; \
	else \
		echo "⏩ Skipping createplex setup (PROJECT_SPACE_SETUP is not True)"; \
		echo ":========== [Phase 1.1] Verifying if project space exists =========="; \
		$(MAKE) robot-run-tests TAGS="verify_project_space_exists" PROJECT_SPACE_SETUP=False || exit 1; \
	fi; \
	\
	echo ":========== [Phase 2] Computing and starting containers using COMPOSE_PROFILES... =========="; \
	$(MAKE) launch-groundplex SWAP_CHECK_DONE=1; \
	\
	echo ":========== [Phase 2.1] Setting permissions for test data directories (Travis only) =========="; \
	if [ "$$TRAVIS" = "true" ]; then \
		chmod +x ./travis_scripts/set_travis_permissions.sh; \
		./travis_scripts/set_travis_permissions.sh || echo "Warning: Could not set all permissions"; \
	else \
		echo "ℹ️ Skipping set_travis_permissions (not running on Travis CI)"; \
	fi; \
	\
	echo ":========== [Phase 3] Running user-defined robot tests... =========="; \
	$(MAKE) robot-run-tests TAGS="$(TAGS)" PROJECT_SPACE_SETUP=False


# =============================================================================
# 🧪 Robot Test Workflow WITHOUT Groundplex Launch
#  → Use this when Groundplex is already running or not needed for your tests.
#  → This target NEVER creates, starts, or stops a Groundplex.
#
#  PROJECT_SPACE_SETUP=True is now the DEFAULT (idempotent, non-destructive):
#    - Project space missing → created with ${PROJECT_NAME}.
#    - Project space exists but ${PROJECT_NAME} missing → only project created.
#    - Both already exist → no-op; the run reuses the existing project.
#    Example: make robot-run-tests-no-gp TAGS="oracle,minio"
#
#  PROJECT_SPACE_SETUP=False — verify-only / fast-fail (no project creation).
#    Example: make robot-run-tests-no-gp TAGS="oracle" PROJECT_SPACE_SETUP=False
#
#  FORCE_RECREATE_PROJECT_SPACE=True (DESTRUCTIVE — opt-in):
#    - Deletes the ENTIRE project space and every project/pipeline/account inside.
#    - Active-nodes handling (if the project space has an attached Groundplex):
#        • LOCAL framework-managed Groundplex (docker container named
#          'snaplogic-groundplex'): auto-stopped, delete retried. Container is
#          left STOPPED afterwards — restart manually with `make launch-groundplex`
#          when you want it back. This target never auto-starts Groundplexes.
#        • EXTERNAL Groundplex (no local container found): fails fast with an
#          "ACTION REQUIRED: stop it externally" message. Framework will NOT
#          touch anything it didn't start.
#    - Requires confirmation; bypass with FORCE_CONFIRM=yes for CI.
#    Example: make robot-run-tests-no-gp TAGS="oracle" FORCE_RECREATE_PROJECT_SPACE=True
# =============================================================================

robot-run-tests-no-gp: check-env
	@# NOTE: Phase 0 (check-groundplex-swap) is intentionally OMITTED here.
	@# This target never starts or stops the Groundplex as part of its normal
	@# flow (only in the narrow FORCE_RECREATE active-nodes recovery branch,
	@# which already has its own local-vs-external detection). A generic swap
	@# warning would contradict the "-no-gp" contract ("framework doesn't
	@# manage your Groundplex"), especially for users running against an
	@# external SnapLogic Cloud plex where the framework should stay hands-off.
	@PROJECT_SPACE_SETUP_ACTUAL=$${PROJECT_SPACE_SETUP:-True}; \
	FORCE_RECREATE_ACTUAL=$${FORCE_RECREATE_PROJECT_SPACE:-False}; \
	echo ":========== [Phase 1] Create project space (No Plex created) =========="; \
	if [ "$$PROJECT_SPACE_SETUP_ACTUAL" = "True" ]; then \
		echo ":========= [Phase 1] Creating Project Space ========================================="; \
		echo "ℹ️  FORCE_RECREATE_PROJECT_SPACE=$$FORCE_RECREATE_ACTUAL (safe default=False)"; \
		$(MAKE) robot-run-tests TAGS="verify_project_space_exists" PROJECT_SPACE_SETUP=True FORCE_RECREATE_PROJECT_SPACE=$$FORCE_RECREATE_ACTUAL FORCE_CONFIRM=$${FORCE_CONFIRM:-} || { \
			echo "❌ Project space setup failed, checking if error is due to active Snaplex nodes..."; \
			LATEST_LOG=$$(ls -t test/robot_output/log-*.html 2>/dev/null | head -1); \
			if [ -n "$$LATEST_LOG" ] && grep -q "cannot be deleted while it contains active nodes" "$$LATEST_LOG" 2>/dev/null; then \
				if docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^snaplogic-groundplex$$'; then \
					echo "🛑 Active nodes detected — framework-managed local Groundplex found."; \
					echo "   Stopping it automatically to unblock destructive recreate..."; \
					echo "   (This is safe: the container 'snaplogic-groundplex' is owned by"; \
					echo "    this framework, not an external system.)"; \
					$(MAKE) stop-groundplex; \
					echo "⏳ Waiting 60 seconds for SnapLogic Cloud to deregister the node..."; \
					sleep 60; \
					echo "🔁 Retrying destructive project space recreate..."; \
					$(MAKE) robot-run-tests TAGS="verify_project_space_exists" PROJECT_SPACE_SETUP=True FORCE_RECREATE_PROJECT_SPACE=$$FORCE_RECREATE_ACTUAL FORCE_CONFIRM=$${FORCE_CONFIRM:-} || exit 1; \
					echo ""; \
					echo "✅ Project space recreated successfully."; \
					echo "ℹ️  Local Groundplex was stopped. Run 'make launch-groundplex' when you want it back."; \
					echo "   (This target does not auto-start Groundplexes — by design.)"; \
				else \
					echo "🛑 Active nodes detected, but no local framework-managed Groundplex container"; \
					echo "   found (no container named 'snaplogic-groundplex' on this host)."; \
					echo "   The Groundplex is external to this framework — framework will NOT touch it."; \
					echo ""; \
					echo "   ACTION REQUIRED: Stop the external Groundplex, then re-run this command."; \
					exit 1; \
				fi; \
			else \
				echo "❌ Project space setup failed for a different reason."; \
				exit 1; \
			fi; \
		}; \
	else \
		echo "⏩ Skipping project space creation (PROJECT_SPACE_SETUP is not True)"; \
		echo ":========== [Phase 1.1] Verifying if project space exists =========="; \
		$(MAKE) robot-run-tests TAGS="verify_project_space_exists" PROJECT_SPACE_SETUP=False || exit 1; \
	fi; \
	\
	echo ":========== [Phase 2] ⏩ SKIPPING Groundplex/Plex operations =========="; \
	echo "ℹ️  Note: This target does not create or manage plex/groundplex"; \
	echo "ℹ️  Ensure Groundplex is already running if your tests require it"; \
	\
	echo ":========== [Phase 2.1] Setting permissions for test data directories (Travis only) =========="; \
	if [ "$$TRAVIS" = "true" ]; then \
		chmod +x ./travis_scripts/set_travis_permissions.sh; \
		./travis_scripts/set_travis_permissions.sh || echo "Warning: Could not set all permissions"; \
	else \
		echo "ℹ️ Skipping set_travis_permissions (not running on Travis CI)"; \
	fi; \
	\
	if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^snaplogic-groundplex$$'; then \
		echo ""; \
		echo "⚠️  ============================================================"; \
		echo "⚠️   GROUNDPLEX IS NOT RUNNING LOCALLY"; \
		echo "⚠️  ============================================================"; \
		echo ""; \
		echo "   No local 'snaplogic-groundplex' container was found on this host."; \
		echo "   This is expected if:"; \
		echo "     • You just finished a destructive recreate (FORCE_RECREATE_PROJECT_SPACE=True)"; \
		echo "       which auto-stopped the local Groundplex (by design — this target"; \
		echo "       does not auto-restart Groundplexes)."; \
		echo "     • You rely on an EXTERNAL Groundplex (remote / shared / customer-hosted)."; \
		echo ""; \
		echo "   Phase 3 will now run your tests. If tests need a running Snaplex:"; \
		echo "     • Tests that poll 'Wait Until Snaplex is Up And Running' will HANG"; \
		echo "       (up to their timeout) until a Groundplex registers against the space."; \
		echo ""; \
		echo "   Options:"; \
		echo "     1. In ANOTHER terminal, run:  make launch-groundplex"; \
		echo "        Phase 3 will auto-recover as soon as the Snaplex reports up."; \
		echo "     2. Abort this run now (Ctrl+C) and use 'make robot-run-all-tests'"; \
		echo "        instead — it manages the Groundplex lifecycle end-to-end."; \
		echo "     3. If you run an external Groundplex, ensure it's attached to the"; \
		echo "        current project space and then ignore this warning."; \
		echo "⚠️  ============================================================"; \
		echo ""; \
	fi; \
	echo ":========== [Phase 3] Running user-defined robot tests... =========="; \
	$(MAKE) robot-run-tests TAGS="$(TAGS)" PROJECT_SPACE_SETUP=False
# =============================================================================
# 🧹 Cleanup stale timestamped projects (safe mode housekeeping)
#   → Deletes ${PROJECT_NAME}_YYYYMMDD_HHMMSS projects older than RETENTION_DAYS.
#   → The un-suffixed ${PROJECT_NAME} is NEVER deleted.
#   → Optional args:
#       RETENTION_DAYS  (default: 7)
#       DRY_RUN         (default: False — set True to preview deletions only)
#   → Examples:
#       make cleanup-stale-projects
#       make cleanup-stale-projects RETENTION_DAYS=14
#       make cleanup-stale-projects RETENTION_DAYS=7 DRY_RUN=True
# =============================================================================
cleanup-stale-projects: check-env
	@echo "🧹 Running stale timestamped project cleanup..."
	$(eval RETENTION_VAL=$(if $(RETENTION_DAYS),$(RETENTION_DAYS),7))
	$(eval DRY_RUN_VAL=$(if $(DRY_RUN),$(DRY_RUN),False))
	@echo "ℹ️  Retention days: $(RETENTION_VAL)"
	@echo "ℹ️  Dry run: $(DRY_RUN_VAL)"
	@$(DOCKER_COMPOSE) exec -w /app/test tools robot \
		--include cleanup_stale_projects \
		--variable PROJECT_SPACE_SETUP:False \
		--variable RETENTION_DAYS:$(RETENTION_VAL) \
		--variable DRY_RUN:$(DRY_RUN_VAL) \
		--outputdir robot_output suite/ && \
	echo "✅ Cleanup completed." || \
	echo "⚠️  Cleanup failed — check logs."

# =============================================================================
# 📢 Send slack notifications for test results
# =============================================================================
slack-notify:
	@echo "📧 Sending Slack notifications for test results..."
	@docker compose --env-file .env -f docker-compose.yml exec \
		-e SLACK_WEBHOOK_URL \
		-w /app/test tools \
		bash -c 'LATEST_OUTPUT=$$(ls -t robot_output/output-*.xml | head -1); \
		         echo "Processing: $$LATEST_OUTPUT"; \
		         python testresults_slack_notifications.py "$$LATEST_OUTPUT"' \
	&& echo "✅ Notifications sent successfully!" \
	|| echo "⚠️ Failed to send notifications"



# =============================================================================
# 📤 Upload Robot Framework test results to S3
# Usage:
#   make upload-test-results                     # Upload all files with zip
#   CREATE_ZIP=false make upload-test-results    # Upload without zip file
#   UPLOAD_LATEST_ONLY=true make upload-test-results  # Upload only latest files
# =============================================================================
upload-test-results:
	@echo "☁️ Uploading test results to S3..."
	@echo "🔍 Checking for AWS credentials..."
	@if [ -z "$AWS_ACCESS_KEY_ID" ] || [ -z "$AWS_SECRET_ACCESS_KEY" ]; then \
		echo "⚠️  AWS credentials not found in environment."; \
		echo "🔍 Checking .env file for credentials..."; \
		if [ -f ".env" ] && grep -q "AWS_ACCESS_KEY_ID" .env && grep -q "AWS_SECRET_ACCESS_KEY" .env; then \
			echo "✅ Found AWS credentials in .env file"; \
			export $(cat .env | grep -E '^AWS_' | xargs); \
		else \
			echo "❌ AWS credentials not found. Please set:"; \
			echo "   export AWS_ACCESS_KEY_ID=your_access_key"; \
			echo "   export AWS_SECRET_ACCESS_KEY=your_secret_key"; \
			echo "   Or add them to your .env file"; \
			exit 1; \
		fi; \
	fi
	@echo "🚀 Running upload script inside tools container..."
	$(DOCKER_COMPOSE) exec -w /app/test -e AWS_ACCESS_KEY_ID -e AWS_SECRET_ACCESS_KEY -e CREATE_ZIP -e UPLOAD_LATEST_ONLY -e LATEST_COUNT tools python upload_robot_results.py




# =============================================================================
# 📤 Export Assets From Project (Full Suite Setup)
#   → Exports assets with full suite initialization (includes credential setup)
#   → This runs the full suite setup which properly initializes authentication
#   → usage: make sl-export-assets
#   → Optional arguments:
#     PROJECT_PATH       - SnapLogic project path to export from
#     ASSET_TYPES        - Types of assets to export: All, Pipeline, Account, File (default: All)
#     EXPORT_FILE_NAME   - Custom ZIP filename
#   → Examples:
#     make sl-export-assets
#     make sl-export-assets PROJECT_PATH="swapna-automation-latest/sl_project" EXPORT_FILE_NAME="prod_backup.zip"
# =============================================================================
sl-export-assets: check-env
	@echo "📤 Exporting assets from SnapLogic project (with full suite initialization)..."
	$(eval ORG_NAME_VALUE := $(shell grep -E '^ORG_NAME=' .env | cut -d '=' -f 2))
	$(eval ROBOT_VARS := )
	$(if $(PROJECT_PATH),$(eval ROBOT_VARS += --variable PROJECT_PATH:$(PROJECT_PATH)))
	$(if $(ASSET_TYPES),$(eval ROBOT_VARS += --variable ASSET_TYPES:$(ASSET_TYPES)))
	$(if $(EXPORT_FILE_NAME),$(eval ROBOT_VARS += --variable EXPORT_FILE_NAME:$(EXPORT_FILE_NAME)))
	@echo "ℹ️  Organization: $(ORG_NAME_VALUE)"
	@if [ -n "$(PROJECT_PATH)" ]; then echo "ℹ️  Project Path: $(PROJECT_PATH)"; fi
	@if [ -n "$(ASSET_TYPES)" ]; then echo "ℹ️  Asset Types: $(ASSET_TYPES)"; fi
	@if [ -n "$(EXPORT_FILE_NAME)" ]; then echo "ℹ️  Export File: $(EXPORT_FILE_NAME)"; fi
	@$(DOCKER_COMPOSE) exec -w /app/test tools robot \
		--include export_assets \
		--outputdir robot_output \
		$(ROBOT_VARS) \
		suite/ && \
	echo "✅ Assets exported successfully!" || \
	echo "❌ Export failed. Check the logs for details."

# =============================================================================
# 📥 Import Assets To Project (Full Suite Setup)
#   → Imports assets with full suite initialization (includes credential setup)
#   → This runs the full suite setup which properly initializes authentication
#   → usage: make sl-import-assets
#   → Optional arguments:
#     IMPORT_PATH          - Target path in SnapLogic where assets will be imported
#     ZIP_FILE_PATH        - Local path to the backup ZIP file to import
#     DUPLICATE_CHECK      - Whether to check for duplicate assets: true or false (default: false)
#     PROJECT_SPACE_SETUP  - Idempotent project space/project ensure: True or False (default: True)
#   → Usage Examples:
#     make sl-import-assets IMPORT_PATH="swapna-automation-latest/test2" ZIP_FILE_PATH="src/exported_assets/prod_backup.zip"
# =============================================================================
sl-import-assets: check-env
	@echo "📥 Importing assets to SnapLogic project (with full suite initialization)..."
	$(eval ORG_NAME_VALUE := $(shell grep -E '^ORG_NAME=' .env | cut -d '=' -f 2))
	$(eval PROJECT_SPACE_SETUP_VAL := $(if $(PROJECT_SPACE_SETUP),$(PROJECT_SPACE_SETUP),True))
	$(eval ROBOT_VARS := --variable PROJECT_SPACE_SETUP:$(PROJECT_SPACE_SETUP_VAL))
	$(if $(IMPORT_PATH),$(eval ROBOT_VARS += --variable IMPORT_PATH:$(IMPORT_PATH)))
	$(if $(ZIP_FILE_PATH),$(eval ROBOT_VARS += --variable ZIP_FILE_PATH:$(ZIP_FILE_PATH)))
	$(if $(DUPLICATE_CHECK),$(eval ROBOT_VARS += --variable DUPLICATE_CHECK:$(DUPLICATE_CHECK)))
	@echo "ℹ️  Organization: $(ORG_NAME_VALUE)"
	@echo "ℹ️  Project Space Setup: $(PROJECT_SPACE_SETUP_VAL)"
	@if [ -n "$(IMPORT_PATH)" ]; then echo "ℹ️  Import Path: $(IMPORT_PATH)"; fi
	@if [ -n "$(ZIP_FILE_PATH)" ]; then echo "ℹ️  ZIP File: $(ZIP_FILE_PATH)"; fi
	@if [ -n "$(DUPLICATE_CHECK)" ]; then echo "ℹ️  Duplicate Check: $(DUPLICATE_CHECK)"; fi
	@$(DOCKER_COMPOSE) exec -w /app/test tools robot \
		--include import_assets \
		--outputdir robot_output \
		$(ROBOT_VARS) \
		suite/ && \
	echo "✅ Assets imported successfully!" || \
	echo "❌ Import failed. Check the logs for details."




################################################################################
# Import SLIM-generated Pipelines (.slp) into SnapLogic project
################################################################################
# 📥 Import Pipeline(s) to Project
#   → Automatically uploads ALL .slp files from GENERATIVE_SLP_PIPELINES_PATH
#   → If PIPELINE_FILE_NAME is specified, uploads only that file
#   → Optional arguments:
#     PIPELINE_FILE_NAME                       - Specific pipeline filename (if omitted, uploads ALL .slp files)
#     PROJECT_PATH                             - Target SnapLogic project path
#     GENERATIVE_SLP_PIPELINES_PATH - Source directory (default: src/generative_pipelines)
#     PROJECT_SPACE_SETUP                      - Idempotent project space/project ensure: True/False (default: True)
#   
#   → Usage Examples:
#     
#     make sl-import-pipeline \
#         PROJECT_PATH="sl_projectspace/sl_project" \
#         GENERATIVE_SLP_PIPELINES_PATH="src/generative_pipelines" \
#         PROJECT_SPACE_SETUP=True
#
#     make sl-import-pipeline \
#         PROJECT_PATH="sl_projectspace/sl_project" \
#         PROJECT_SPACE_SETUP=True

import-slim-generated-pipelines: check-env
	@echo "Importing SLIM-generated pipeline(s) into SnapLogic project..."
	@echo "================================================================="

	$(eval PROJECT_SPACE_SETUP_VAL := $(if $(PROJECT_SPACE_SETUP),$(PROJECT_SPACE_SETUP),True))

	$(eval PROJECT_PATH_VAL := \
		$(if $(PROJECT_PATH),$(PROJECT_PATH),\
			$(shell grep -E '^PROJECT_SPACE=' .env | cut -d '=' -f 2)/\
			$(shell grep -E '^PROJECT_NAME=' .env | cut -d '=' -f 2)))

	$(if $(GENERATIVE_SLP_PIPELINES_PATH),\
		$(eval RAW_PIPELINE_PATH := $(GENERATIVE_SLP_PIPELINES_PATH)),\
		$(eval RAW_PIPELINE_PATH := src/generative_pipelines))

	$(if $(filter /app/%,$(RAW_PIPELINE_PATH)),\
		$(eval NORMALIZED_PIPELINE_PATH := $(RAW_PIPELINE_PATH)),\
		$(eval NORMALIZED_PIPELINE_PATH := /app/$(RAW_PIPELINE_PATH)))

	@echo "Pipeline directory inside container: $(NORMALIZED_PIPELINE_PATH)"

	@if ! $(DOCKER_COMPOSE) exec -T tools test -d "$(NORMALIZED_PIPELINE_PATH)"; then \
		echo "ERROR: Directory $(NORMALIZED_PIPELINE_PATH) does not exist."; \
		exit 1; \
	fi

	@if [ -n "$(PIPELINE_FILE_NAME)" ]; then \
		echo "Uploading specific pipeline: $(PIPELINE_FILE_NAME)"; \
		$(DOCKER_COMPOSE) exec -T -w /app/test tools \
			robot --include upload_pipeline --outputdir robot_output \
			"--variable" "PROJECT_SPACE_SETUP:$(PROJECT_SPACE_SETUP_VAL)" \
			"--variable" "pipeline_file_name:$(PIPELINE_FILE_NAME)" \
			"--variable" "project_path:$(PROJECT_PATH_VAL)" \
			"--variable" "GENERATIVE_SLP_PIPELINES_PATH:$(NORMALIZED_PIPELINE_PATH)" \
			suite/ \
			|| (echo "Pipeline import failed." && exit 1); \
	else \
		echo "Uploading all pipelines from $(NORMALIZED_PIPELINE_PATH)"; \
		PIPELINE_FILES=$$($(DOCKER_COMPOSE) exec -T tools find $(NORMALIZED_PIPELINE_PATH) -maxdepth 1 -name "*.slp" -type f | xargs -n1 basename); \
		if [ -z "$$PIPELINE_FILES" ]; then echo "No .slp files found."; exit 1; fi; \
		TOTAL=$$(echo "$$PIPELINE_FILES" | wc -l); \
		echo "Total pipelines found: $$TOTAL"; \
		FAILED=0; \
		for FILE in $$PIPELINE_FILES; do \
			echo "Uploading $$FILE"; \
			if ! $(DOCKER_COMPOSE) exec -T -w /app/test tools \
				robot --include upload_pipeline --outputdir robot_output \
				"--variable" "PROJECT_SPACE_SETUP:$(PROJECT_SPACE_SETUP_VAL)" \
				"--variable" "pipeline_file_name:$$FILE" \
				"--variable" "project_path:$(PROJECT_PATH_VAL)" \
				"--variable" "GENERATIVE_SLP_PIPELINES_PATH:$(NORMALIZED_PIPELINE_PATH)" \
				suite/ ; then \
					FAILED=$$((FAILED + 1)); \
				fi; \
		done; \
		if [ $$FAILED -eq 0 ]; then echo "All pipelines imported successfully."; \
		else echo "$$FAILED pipelines failed to import."; fi; \
	fi