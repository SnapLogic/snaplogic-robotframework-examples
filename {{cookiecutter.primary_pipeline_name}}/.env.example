# copy the below details to .env file and update the values as per your requirements
# This file is used to configure the SnapLogic Robot Framework examples project.
# NOTE: In .env file remove inline comments

# ============================================================================
#                         SNAPLOGIC INSTANCE CONFIGURATION
# ============================================================================
URL=https://example.com/
ORG_NAME=org_name

# ============================================================================
#                         AUTHENTICATION CONFIGURATION
# ============================================================================
# AUTH_METHOD controls how the framework authenticates with SnapLogic APIs.
# Supported values: basic (default), jwt, oauth2, sltoken
# If AUTH_METHOD is not set, it is auto-detected from available env vars.
#
# --- Option 1: Basic Auth (default) ---
# Traditional username/password authentication.
# AUTH_METHOD=basic
ORG_ADMIN_USER=your_username
ORG_ADMIN_PASSWORD=your_password
#
# --- Option 2: JWT / Bearer Token ---
# Uses a pre-generated JWT token from your Identity Provider (Okta, Entra ID, etc.).
# Requires JWT to be configured in SnapLogic Admin Manager > Authentication > JWT tab.
# AUTH_METHOD=jwt
# BEARER_TOKEN=your_jwt_token_here
#
# --- Option 3: OAuth2 Client Credentials ---
# Automatically fetches an access token from your Identity Provider at runtime.
# Requires JWT to be configured in SnapLogic Admin Manager > Authentication > JWT tab.
# AUTH_METHOD=oauth2
# OAUTH2_TOKEN_URL=https://your-idp.com/oauth2/default/v1/token
# OAUTH2_CLIENT_ID=your_client_id
# OAUTH2_CLIENT_SECRET=your_client_secret
# OAUTH2_SCOPE=optional_scope
#
# --- Option 4: SnapLogic Session Token (SLToken) ---
# Authenticates with username/password once to get a session token, then uses
# the token for all subsequent API calls. No Identity Provider required.
# Uses the same ORG_ADMIN_USER and ORG_ADMIN_PASSWORD as basic auth.
# AUTH_METHOD=sltoken
# ============================================================================


# All configurations below this point will be automatically created during
# the execution of automated setup scripts

# ============================================================================
#                         PROJECT SPACE CONFIGURATION
# ============================================================================
# Eg: sl-automation-ps
PROJECT_SPACE=project_space 
 # Eg: sl_project``
PROJECT_NAME=project_name
# eg: sl-automation-ps/sl_project
PROJECT_PATH=project_space/project_name
# eg: sl-automation-ps/shared
PROJECT_SPACE_SHARED_PATH=project_space/shared

# ============================================================================
#                         GROUNDPLEX CONFIGURATION
# ============================================================================
#Eg: sl-groundplex-automation
GROUNDPLEX_NAME=groundplex_name 

###comment out below variables if you are using EXISTING plex( which is already created)
#Eg: slgroundplexautomationdev
GROUNDPLEX_ENV=groundplex_environment_name 
#Eg: main-30027
RELEASE_BUILD_VERSION=build_version  
# eg: sl-automation-ps/shared
GROUNDPLEX_LOCATION_PATH=your_groundplex_location_path 


# ============================================================================
#                    PIPELINES AND ACCOUNTS CONFIGURATION
# ============================================================================
# Specify the storage locations for pipelines and account credentials
PIPELINES_LOCATION_PATH=project_space/shared
ACCOUNT_LOCATION_PATH=project_space/project_name



# ============================================================================
#                      EXTERNAL ACCOUNTS CONFIGURATION
# ============================================================================
# Configure accounts for external endpoints that are not managed by Docker
# instances. These credentials should be kept secure and never committed to
# version control.
#
# SECURITY NOTICE: Store sensitive credentials in your .env file or configure
# them through your CI/CD environment variables
# ============================================================================

# ============================================================================
#                         SNOWFLAKE ACCOUNT CONFIGURATION
# ============================================================================
# Configure Snowflake database connection settings
# Skip this section if your pipeline execution does not require Snowflake Account

SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
# Account configuration [Account name can also be updated as needed in respective test cases]
SNOWFLAKE_ACCOUNT_NAME=snowflake_acct
SNOWFLAKE_HOSTNAME=snaplogic.snowflakecomputing.com
# Database configuration
SNOWFLAKE_DATABASE=FDLDB
SNOWFLAKE_SCHEMA=DEMO
SNOWFLAKE_WAREHOUSE=ELT_XS_WH
SNOWFLAKE_ROLE=SYSADMIN
# S3 Integration (for external stages)
SNOWFLAKE_S3_BUCKET=
SNOWFLAKE_S3_FOLDER=
SNOWFLAKE_S3_ACCESS_KEY=
SNOWFLAKE_S3_SECRET_KEY=

# ============================================================================
#                      ADDITIONAL EXTERNAL ACCOUNTS
# ============================================================================
# Add configuration for any additional external accounts as needed for your
# specific testing scenarios. Follow the same pattern as the Snowflake
# configuration above.
# ============================================================================


# ============================================
# SLACK WEBHOOK ACCOUNT- For slack notification. Add this to .env file as needed
# ============================================
SLACK_WEBHOOK_URL=webhook url
